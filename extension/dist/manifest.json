{
    "manifest_version": 3, 
    "name": "Eco-Prompter",
    "description": "Extension using React and webpack",
    "version":"1.0.0",
    "permissions": ["sidePanel"],
    "side_panel": {
        "default_path": "dist/index.html"
      },
    "background": {
       "service_worker": "dist/background.js"
    },"action": {},
    "content_scripts": [
        {
            "matches": ["https://chatgpt.com/*",
      "https://chat.openai.com/*"], 
            "js": ["dist/contentScript.js"]
        }
    ]

}
